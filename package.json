{
  "name": "par-stock",
  "version": "1.0.0",
  "private": true,
  "description": "Controle de Estoque e Vendas para PDV (hotéis) — sistema web com perfis, validação e banco de dados.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build",
    "start": "node server/index.js",
    "postinstall": "node -e \"process.exit(0)\"",
    "start:builtin": "node --experimental-sqlite server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pg-mem": "^3.0.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "vite": "^5.4.2"
  }
}
